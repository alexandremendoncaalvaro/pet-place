{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a resident or an admin.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "dogName": { "type": "string" },
        "photoUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "resident"] },
        "email": { "type": "string" },
        "fcmToken": { "type": "string" },
        "familyId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "role", "email", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a resident's contribution.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "proofUrl": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "analyzing", "approved", "rejected"]
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "familyId",
        "month",
        "amount",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "Expense": {
      "title": "Expense",
      "description": "Represents a community expense.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "receiptUrl": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": [
        "date",
        "title",
        "category",
        "amount",
        "createdBy",
        "createdAt"
      ]
    },
    "Pet": {
      "title": "Pet",
      "description": "Represents a pet owned by a resident.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "breed": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["ownerId", "name", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "Notice or Event for the community.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["event", "announcement"] },
        "notify24h": { "type": "boolean" },
        "notify1h": { "type": "boolean" },
        "notifyNow": { "type": "boolean" },
        "notified24h": { "type": "boolean" },
        "notified1h": { "type": "boolean" },
        "notifiedNow": { "type": "boolean" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": [
        "title",
        "description",
        "type",
        "notify24h",
        "notify1h",
        "notifyNow",
        "readBy",
        "createdBy",
        "createdAt"
      ]
    },
    "Notification": {
      "title": "Notification",
      "description": "User specific notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "isRead", "createdAt"]
    },
    "AppPost": {
      "title": "AppPost",
      "description": "User post for feed.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" }
      },
      "required": ["authorId", "content", "likedBy", "createdAt"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["postId", "authorId", "content", "createdAt"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "pixKey": { "type": "string" },
        "monthlyAmount": { "type": "number" },
        "dueDateDay": { "type": "number" },
        "paymentInstructions": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": [
        "pixKey",
        "monthlyAmount",
        "dueDateDay",
        "paymentInstructions",
        "updatedAt"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Contains user profiles."
    },
    "payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Contains payments for all users. Kept flat for easy admin querying and aggregation."
    },
    "expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Contains community expenses. Public for reading, admin only for writing."
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/AppConfig" },
      "description": "Global settings like pix key and default values."
    },
    "pets/{petId}": {
      "schema": { "$ref": "#/entities/Pet" },
      "description": "Contains pets."
    },
    "events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Contains events and announcements."
    },
    "notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Contains notifications."
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/AppPost" },
      "description": "Feed posts."
    },
    "postComments/{commentId}": {
      "schema": { "$ref": "#/entities/PostComment" },
      "description": "Comments on feed posts."
    }
  }
}
