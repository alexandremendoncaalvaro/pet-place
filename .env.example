# Frontend override for local Vite-only development.
# In production, the Worker serves the app and /api on the same origin.
VITE_API_URL=""

# Worker vars/secrets. Configure secrets with:
# npx wrangler secret put GOOGLE_CLIENT_ID
# npx wrangler secret put GOOGLE_CLIENT_SECRET
# npx wrangler secret put SESSION_SECRET
# npx wrangler secret put VAPID_PUBLIC_KEY
# npx wrangler secret put VAPID_PRIVATE_KEY
APP_URL="https://pet-place.example.com"
BOOTSTRAP_ADMIN_EMAIL="peritto@gmail.com"
VAPID_SUBJECT="mailto:peritto@gmail.com"
