rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isBootstrappedAdmin() {
      return isSignedIn() && request.auth.token.email == 'peritto@gmail.com';
    }

    function isAdmin() {
      return isBootstrappedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserFamilyId() {
      let isUser = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      let data = isUser ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {};
      return isUser && 'familyId' in data && data.familyId != "" ? data.familyId : request.auth.uid;
    }

    function hasAllKeys(data, keys) {
      return data.keys().hasAll(keys) && data.keys().size() == keys.size();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'phone', 'dogName', 'photoUrl', 'role', 'email', 'createdAt'])
        && data.keys().hasOnly(['uid', 'name', 'phone', 'dogName', 'photoUrl', 'role', 'email', 'createdAt', 'fcmToken', 'familyId', 'userStatus'])
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 100
        && data.name is string && data.name.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.dogName is string && data.dogName.size() <= 100
        && data.photoUrl is string && data.photoUrl.size() <= 1000
        && data.role is string && data.role in ['admin', 'resident']
        && (!('fcmToken' in data) || data.fcmToken is string)
        && (!('familyId' in data) || (data.familyId is string && data.familyId.size() <= 100))
        && (!('userStatus' in data) || (data.userStatus is string && data.userStatus in ['pending', 'active', 'blocked']))
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'photoUrl', 'dogName', 'role', 'createdAt'])
        && data.keys().hasOnly(['uid', 'name', 'photoUrl', 'dogName', 'role', 'createdAt', 'familyId'])
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 100
        && data.name is string && data.name.size() <= 100
        && data.photoUrl is string && data.photoUrl.size() <= 1000
        && data.dogName is string && data.dogName.size() <= 100
        && data.role is string && data.role in ['admin', 'resident']
        && (!('familyId' in data) || (data.familyId is string && data.familyId.size() <= 100))
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /public_profiles/{profileId} {
      allow read: if isSignedIn();
      allow create: if isOwner(profileId) && isValidId(profileId)
                    && isValidPublicProfile(incoming())
                    && incoming().uid == request.auth.uid;
      allow update: if isOwner(profileId) && isValidId(profileId)
                    && isValidPublicProfile(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'dogName', 'photoUrl', 'role', 'familyId'])
                    && incoming().uid == existing().uid
                    && incoming().createdAt == existing().createdAt
                    || (isAdmin() && isValidPublicProfile(incoming()));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow users to create their own profile. Only bootstrapped admin can create an admin profile directly, others must create as resident.
      allow create: if isOwner(userId) && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().uid == request.auth.uid
                    && incoming().email == request.auth.token.email
                    && (incoming().role == 'resident' || isBootstrappedAdmin());
      
      allow update: if isOwner(userId) && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'dogName', 'photoUrl', 'fcmToken', 'familyId'])
                    && incoming().uid == existing().uid
                    && incoming().email == existing().email
                    && incoming().role == existing().role
                    && incoming().createdAt == existing().createdAt
                    || (isAdmin() && isValidUser(incoming()));
      allow delete: if isAdmin();
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['familyId', 'month', 'amount', 'proofUrl', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 9
        && data.familyId is string && data.familyId.size() > 0 && data.familyId.size() <= 100
        && data.month is string && data.month.size() > 0 && data.month.size() <= 20
        && data.amount is number && data.amount >= 0
        && data.proofUrl is string && data.proofUrl.size() <= 1000
        && data.status is string && data.status in ['pending', 'analyzing', 'approved', 'rejected']
        && (!('type' in data) || (data.type is string && data.type in ['mensalidade', 'doacao', 'rateio']))
        && (!('description' in data) || (data.description is string && data.description.size() <= 200))
        && data.createdAt is string && data.createdAt.size() > 0
        && data.updatedAt is string && data.updatedAt.size() > 0;
    }

    match /payments/{paymentId} {
      // Todos logados leem, mas as verificações ocorrem na interface (Transparência).
      allow read: if isSignedIn();
      
      // Residents can create payments.
      allow create: if isSignedIn() && isValidId(paymentId)
                    && isValidPayment(incoming())
                    && (
                      (incoming().familyId == getUserFamilyId() && (incoming().status == 'pending' || incoming().status == 'analyzing'))
                      || isAdmin()
                    );

      // Residents can update their family's payment to attach proof ('analyzing' status).
      // Admins can approve/reject.
      allow update: if isSignedIn() && isValidId(paymentId)
                    && isValidPayment(incoming())
                    && incoming().familyId == existing().familyId
                    && incoming().month == existing().month
                    && incoming().createdAt == existing().createdAt
                    && (
                      (
                        incoming().familyId == getUserFamilyId()
                        && existing().status in ['pending', 'rejected']
                        && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'proofUrl', 'status', 'updatedAt'])
                        && incoming().status == 'analyzing'
                      )
                      ||
                      (
                        isAdmin()
                        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'proofUrl'])
                      )
                    );
                    
      // Admins can delete, or users can delete duplicate pending
      allow delete: if isAdmin() || (isSignedIn() && existing().familyId == getUserFamilyId() && existing().status == 'pending');
    }

    function isValidExpense(data) {
      return hasAllKeys(data, ['date', 'title', 'category', 'amount', 'receiptUrl', 'createdBy', 'createdAt'])
        && data.date is string && data.date.size() > 0 && data.date.size() <= 20
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.amount is number && data.amount >= 0
        && data.receiptUrl is string && data.receiptUrl.size() <= 1000
        && data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() <= 100
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /expenses/{expenseId} {
      // Transparência: Todos os moradores logados podem ler as despesas.
      allow read: if isSignedIn();

      allow create: if isAdmin() && isValidId(expenseId)
                    && isValidExpense(incoming())
                    && incoming().createdBy == request.auth.uid;

      allow update: if isAdmin() && isValidId(expenseId)
                    && isValidExpense(incoming())
                    && incoming().createdBy == existing().createdBy
                    && incoming().createdAt == existing().createdAt;
      
      allow delete: if isAdmin() && isValidId(expenseId);
    }

    function isValidAppConfig(data) {
      return hasAllKeys(data, ['pixKey', 'monthlyAmount', 'dueDateDay', 'paymentInstructions', 'updatedAt'])
        && data.pixKey is string && data.pixKey.size() <= 100
        && data.monthlyAmount is number && data.monthlyAmount >= 0
        && data.dueDateDay is number && data.dueDateDay >= 1 && data.dueDateDay <= 31
        && data.paymentInstructions is string && data.paymentInstructions.size() <= 2000
        && data.updatedAt is string && data.updatedAt.size() > 0;
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(settingId)
                    && isValidAppConfig(incoming());
      allow update: if isAdmin() && isValidId(settingId)
                    && isValidAppConfig(incoming());
    }

    function isValidPet(data) {
      return hasAllKeys(data, ['ownerId', 'name', 'photoUrl', 'breed', 'createdAt'])
        && data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() <= 100
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.photoUrl is string && data.photoUrl.size() <= 1000
        && data.breed is string && data.breed.size() <= 100
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /pets/{petId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(petId)
                    && isValidPet(incoming())
                    && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(petId)
                    && isValidPet(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().createdAt == existing().createdAt
                    && (incoming().ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && isValidId(petId) && (existing().ownerId == request.auth.uid || isAdmin());
    }

    function isValidEventConfig(data) {
      let requiredKeys = ['title', 'description', 'date', 'time', 'type', 'notify24h', 'notify1h', 'notifyNow', 'readBy', 'createdBy', 'createdAt'];
      return data.keys().hasAll(requiredKeys)
        && data.keys().size() >= 11 && data.keys().size() <= 14
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 20
        && data.type is string && data.type in ['event', 'announcement']
        && data.notify24h is bool
        && data.notify1h is bool
        && data.notifyNow is bool
        && data.readBy is list && data.readBy.size() <= 1000
        && (data.readBy.size() == 0 || data.readBy[0] is string)
        && data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() <= 100
        && data.createdAt is string && data.createdAt.size() > 0
        && (!('notified24h' in data) || data.notified24h is bool)
        && (!('notified1h' in data) || data.notified1h is bool)
        && (!('notifiedNow' in data) || data.notifiedNow is bool);
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(eventId)
                    && isValidEventConfig(incoming())
                    && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidId(eventId)
                    && isValidEventConfig(incoming())
                    && incoming().createdBy == existing().createdBy
                    && incoming().createdAt == existing().createdAt
                    && (
                      isAdmin()
                      ||
                      (
                        incoming().diff(existing()).affectedKeys().hasOnly(['readBy'])
                        && incoming().readBy.hasAll(existing().readBy)
                      )
                    );
      allow delete: if isAdmin() && isValidId(eventId);
    }

    function isValidNotification(data) {
      return hasAllKeys(data, ['userId', 'title', 'message', 'isRead', 'createdAt'])
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 100
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.isRead is bool
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all' || resource.data.userId == 'admins' || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming()) && (isAdmin() || incoming().userId == 'admins');
      // we allow user to update isRead
      allow update: if isSignedIn() && isValidId(notificationId)
                    && isValidNotification(incoming())
                    && incoming().userId == existing().userId
                    && incoming().title == existing().title
                    && incoming().message == existing().message
                    && incoming().createdAt == existing().createdAt
                    && (
                      (incoming().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']))
                      || isAdmin()
                    );
      allow delete: if isAdmin() && isValidId(notificationId);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'likedBy', 'createdAt'])
        && data.keys().size() >= 4 && data.keys().size() <= 7
        && data.authorId is string && data.authorId.size() > 0 && data.authorId.size() <= 100
        && data.content is string && data.content.size() <= 2000
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 1000))
        && (!('mediaType' in data) || (data.mediaType is string && data.mediaType in ['image', 'video']))
        && data.likedBy is list && data.likedBy.size() <= 1000
        && (data.likedBy.size() == 0 || data.likedBy[0] is string)
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 20 && (data.tags.size() == 0 || data.tags[0] is string)))
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(postId) && isValidPost(incoming())
        && incoming().authorId == existing().authorId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['likedBy'])
          || (incoming().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'tags']))
          || isAdmin()
        );
      allow delete: if isSignedIn() && isValidId(postId) && (existing().authorId == request.auth.uid || isAdmin());
    }

    function isValidPostComment(data) {
      return data.keys().hasAll(['postId', 'authorId', 'content', 'createdAt'])
        && data.keys().size() == 4
        && data.postId is string && data.postId.size() > 0 && data.postId.size() <= 100
        && data.authorId is string && data.authorId.size() > 0 && data.authorId.size() <= 100
        && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
        && data.createdAt is string && data.createdAt.size() > 0;
    }

    match /postComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(commentId) && isValidPostComment(incoming()) && incoming().authorId == request.auth.uid && exists(/databases/$(database)/documents/posts/$(incoming().postId));
      allow update: if false;
      allow delete: if isSignedIn() && isValidId(commentId) && (
        existing().authorId == request.auth.uid 
        || isAdmin() 
        || (exists(/databases/$(database)/documents/posts/$(existing().postId)) && get(/databases/$(database)/documents/posts/$(existing().postId)).data.authorId == request.auth.uid)
      );
    }
  }
}
